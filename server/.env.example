# Database connection (provided by Railway when you add PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/canopy

# Admin API key for managing events/schedules (generate any random string)
ADMIN_API_KEY=your-secret-admin-key-here

# Ticketmaster API key (for proxied event discovery)
TICKETMASTER_API_KEY=your-ticketmaster-key-here

# Anthropic API key for AI schedule parsing (get at console.anthropic.com)
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Apple Push Notification service (APNs)
# Get these from Apple Developer Portal > Keys > create an APNs Auth Key
APNS_KEY_ID=your-key-id
APNS_TEAM_ID=your-team-id
APNS_BUNDLE_ID=btt.canopy
APNS_PRODUCTION=false
# For local dev: path to .p8 file
APNS_KEY_PATH=./AuthKey.p8
# For cloud deployment: base64-encoded .p8 contents (use: base64 -i AuthKey.p8)
# APNS_KEY_CONTENTS=base64-encoded-key-here

# Environment
NODE_ENV=development
PORT=3000
